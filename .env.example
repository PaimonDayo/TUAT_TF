NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Web Push: NEXT_PUBLIC_VAPID_PUBLIC_KEY goes to Next.js/Vercel.
# VAPID_* and PUSH_WEBHOOK_SECRET go to Supabase Edge Function secrets.
# Store the same PUSH_WEBHOOK_SECRET in Supabase Vault as push_webhook_secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace_with_vapid_public_key
VAPID_PUBLIC_KEY=replace_with_the_same_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_vapid_private_key
VAPID_SUBJECT=mailto:club-admin@example.com
PUSH_WEBHOOK_SECRET=replace_with_a_long_random_webhook_secret

NEXT_PUBLIC_UNIVERSITY_DOMAIN=st.your-univ.ac.jp
GOOGLE_DRIVE_CLIENT_ID=your_drive_oauth_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_drive_oauth_client_secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/google/callback
# 練習記録シート同期
# 読み取りは公開CSV、書き込みはGASを使用する。
SHEET_SYNC_SPREADSHEET_ID=replace_with_google_spreadsheet_id
SHEET_SYNC_GAS_URL=https://script.google.com/macros/s/your-deployment-id/exec
SHEET_SYNC_SECRET=replace_with_a_long_random_value
SHEET_SYNC_ENABLED=false
SHEET_SYNC_CONCURRENCY=4
SHEET_SYNC_PUSH_LIMIT=25
SHEET_SYNC_CHUNK_SIZE=16
